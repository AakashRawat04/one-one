NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# LiveKit token signing. Do not commit real values.
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

# Firebase Admin SDK. Prefer service account JSON in deployment secrets.
FIREBASE_PROJECT_ID=replace-me
FIREBASE_CLIENT_EMAIL=replace-me
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://replace-me.firebaseio.com

# Comma-separated HTTPS origins for future browser/admin clients.
CORS_ORIGINS=
