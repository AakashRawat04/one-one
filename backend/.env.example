NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# LiveKit token signing. Do not commit real values.
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

# Firebase Admin SDK.
# Option A: set GOOGLE_APPLICATION_CREDENTIALS outside this file.
# Option B: use the explicit service-account fields below.
FIREBASE_PROJECT_ID=replace-me
FIREBASE_CLIENT_EMAIL=replace-me
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
# Use the exact Realtime Database URL from Firebase Console.
# Region-based databases usually look like:
# https://your-project-id-default-rtdb.region.firebasedatabase.app
FIREBASE_DATABASE_URL=https://replace-me-default-rtdb.region.firebasedatabase.app
# Private bucket used for short-lived voice nudges.
FIREBASE_STORAGE_BUCKET=replace-me.firebasestorage.app

# Public HTTPS origin of this API. Sent to Android devices for short-lived
# voice-nudge download and acknowledgement callbacks.
PUBLIC_API_BASE_URL=https://api.example.com

# SHA-256 hashes of high-entropy developer redeem codes, comma-separated.
# Generate one with:
# printf %s 'YOUR-LONG-CODE' | tr '[:lower:]' '[:upper:]' | shasum -a 256
SUBSCRIPTION_REDEEM_CODE_HASHES=

# Comma-separated HTTPS origins for future browser/admin clients.
CORS_ORIGINS=
